# PostgreSQL connection string (Railway provides this automatically)
DATABASE_URL="postgresql://user:password@localhost:5432/cityjobs"

# Admin access secret — required to use /admin
ADMIN_SECRET="choose-a-strong-secret"

# Mercado Pago (Checkout Transparente) — get these at
# https://www.mercadopago.com.br/developers → Suas integrações → sua aplicação → Credenciais
MERCADOPAGO_ACCESS_TOKEN="APP_USR-xxxxxxxx"          # backend (secret)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-xxxxxxxx" # frontend (public)
# Optional: MP will POST payment updates here (needed for PIX confirmation)
MERCADOPAGO_WEBHOOK_URL="https://seu-dominio/api/payments/webhook"
