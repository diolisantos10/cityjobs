generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Niche {
  VAREJO
  SAUDE
  ESCRITORIO
  RESTAURANTE
  LOGISTICA
}

enum ContractType {
  CLT
  PJ
  FREELANCER
  TEMPORARIO
  ESTAGIO
  OUTRO
}

enum ApplicationMethod {
  WHATSAPP
  LINK
  EMAIL
  OTHER
}

enum JobStatus {
  DRAFT
  AWAITING_PAYMENT
  PAID
  IN_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  ARCHIVED
}

enum ArtMode {
  WE_CREATE   // CityJobs cria a arte (pago) — passa pela anamnese + agente de design
  SELF_UPLOAD // Cliente envia a própria arte (incluído)
}

enum AssetKind {
  ART  // arte final enviada pelo cliente (SELF_UPLOAD)
  LOGO // logo do cliente (para o agente de design usar)
}

model Company {
  id          String    @id @default(cuid())
  name        String
  cnpj        String?
  contactName String?
  whatsapp    String?
  email       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  jobPosts    JobPost[]
}

model JobPost {
  id                  String            @id @default(cuid())
  companyId           String?
  company             Company?          @relation(fields: [companyId], references: [id])
  companyName         String
  cnpj                String?
  roleTitle           String
  niche               Niche
  neighborhood        String
  city                String            @default("São Paulo")
  contractType        ContractType
  salary              String
  benefits            String?
  applicationMethod   ApplicationMethod
  applicationWhatsapp String?
  applicationLink     String?
  selectedPlanDays    Int
  priceInCents        Int               // total cobrado = plano + criação de arte
  planPriceInCents    Int               @default(0) // parcela do plano
  paymentLink         String
  status              JobStatus         @default(AWAITING_PAYMENT)
  moderationNotes     String?
  trustFlags          Json?
  storyCopy           String?

  // Arte do Story
  artMode             ArtMode?          // WE_CREATE | SELF_UPLOAD
  artDesignCount      Int?              // 1 ou 2, quando WE_CREATE
  artPriceInCents     Int               @default(0) // add-on da criação de arte
  designBrief         Json?             // anamnese: { useLogo, style, colors, notes }
  assets              Asset[]

  // Agenda de publicação
  scheduledFor        DateTime?
  publishedAt         DateTime?

  // Mercado Pago (Checkout Transparente) tracking
  mpPaymentId         String?           @unique
  mpStatus            String?           // approved | pending | in_process | rejected | ...
  mpStatusDetail      String?
  paidAt              DateTime?

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([status])
  @@index([niche])
  @@index([createdAt])
}

// Uploads (arte final / logo) armazenados no próprio banco para evitar
// dependência de storage externo no MVP. Servidos via /api/assets/[id].
model Asset {
  id        String    @id @default(cuid())
  jobId     String
  job       JobPost   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  kind      AssetKind
  mime      String
  data      Bytes
  createdAt DateTime  @default(now())

  @@index([jobId])
}

// Preço da criação de arte, configurável no /admin (por quantidade de designs).
model ArtPriceConfig {
  id           String   @id @default(cuid())
  designCount  Int      @unique // 1 ou 2
  label        String
  priceInCents Int
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PlanConfig {
  id           String   @id @default(cuid())
  days         Int      @unique
  label        String
  priceInCents Int
  paymentLink  String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
